# ---------------------------------------------------------------------------
# Claude Subscription Gateway — example configuration.
# Copy to `.env` and edit. Every value here has a sane default except
# GATEWAY_API_KEYS, which you MUST set (the gateway rejects all requests until
# at least one key is configured).
# ---------------------------------------------------------------------------

# Comma-separated list of client API keys (the Bearer tokens your tools send).
# Generate strong random values, e.g.:  python -c "import secrets; print('sk-gw-'+secrets.token_hex(24))"
GATEWAY_API_KEYS=sk-gw-changeme-0001,sk-gw-changeme-0002

# Model used when a client omits `model` (or sends an empty value).
DEFAULT_MODEL=claude-sonnet-4-6

# Extra model aliases mapping friendly names -> real Claude ids.
# JSON object form:
#   MODEL_ALIASES={"gpt-4o":"claude-opus-4-8","my-fast":"claude-haiku-4-5"}
# or comma/colon form:
#   MODEL_ALIASES=gpt-4o:claude-opus-4-8,my-fast:claude-haiku-4-5
# (Built-in aliases like opus/sonnet/haiku and gpt-4o already work without this.)
MODEL_ALIASES=

# Max concurrent Claude CLI subprocesses. Requests beyond this queue (FIFO).
MAX_CONCURRENCY=4

# Idle timeout in seconds: max wait for the NEXT event from the backend. A stalled
# model trips it; a slow client reading a stream does not. (For non-streaming the
# whole reply is one event, so this is effectively the total generation budget.)
REQUEST_TIMEOUT=600

# Server bind address.
HOST=0.0.0.0
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS: comma-separated allowed origins, or "*" for any (needed for browser
# clients like OpenWebUI). Credentials are disabled automatically when "*".
CORS_ORIGINS=*
